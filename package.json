{
  "name": "bolao-copa-2026",
  "version": "1.0.0",
  "description": "World Cup 2026 betting pool",
  "type": "module",
  "scripts": {
    "build:config": "node scripts/build-config.js",
    "setup": "npm install && npm run build:config",
    "dev": "npx serve src -l 3000",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "test:rls": "node scripts/e2e/test-rls-hostile.js",
    "test:render": "node scripts/e2e/test-render-adversarial.js",
    "test:xss": "node scripts/e2e/test-xss-hostile.js",
    "test:integrity": "node scripts/e2e/test-integrity-snapshot.js",
    "verify:prod": "node scripts/e2e/prod-verify.js",
    "sync:squads": "node scripts/data/sync-squads.js",
    "sync:h2h": "node scripts/data/fetch-h2h.js",
    "sync:h2h-pairs": "node scripts/data/fetch-h2h-pairs.js",
    "sync:odds": "node scripts/data/fetch-odds.js",
    "sync:predictions": "node scripts/data/fetch-predictions.js",
    "sync:qualifiers": "node scripts/data/fetch-qualifiers.js",
    "sync:topscorers": "node scripts/data/fetch-topscorers.js",
    "sync:standings": "node scripts/data/fetch-standings.js",
    "integrity:snapshot": "node scripts/integrity/snapshot.js",
    "integrity:verify": "node scripts/integrity/verify.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@vitest/coverage-v8": "^3.1.0",
    "dotenv": "^16.6.1",
    "jsdom": "^26.1.0",
    "serve": "^14.2.0",
    "vitest": "^3.1.0"
  },
  "keywords": [
    "world-cup",
    "betting-pool",
    "supabase"
  ],
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "flag-icons": "^7.5.0"
  }
}
